# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
**/.next/
**/out/

# production
**/build

# misc
.DS_Store
*.pem
.scratchpad/*copy*.md

# expo
**/.expo/
apps/mobile/dist/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# turbo cache
.turbo/
**/.turbo/

# local data / docs / assets not tracked in git
apps/web/data/
docs/
# ...except curated pack source drafts, which tracked code references
!docs/packs/
!docs/packs/**

# pronunciation audio test output (throwaway)
/audio-test/

# Firebase service account keys — never commit, live credential
*firebase-adminsdk*.json
serviceAccountKey*.json
apps/web/src/components/AmgiLogo*.png
apps/web/src/components/AmgiLogo*.svg
"apps/web/src/components/AmgiLogo 1 (1).png"
"apps/web/src/components/AmgiLogo 1.png"
